<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Scientia Naturalis | Education Credential Verification</title>
  <meta name="description" content="High-Stakes Knowledge Arbitrage at the Scientific-Policy-Finance Interface. W3C Verifiable Credentials, Erasmus+ CBHE modular training." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:wght@300;400;600&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;1,9..144,300&display=swap" rel="stylesheet" />
  <style>
    /* ── TOKENS ──────────────────────────────────────────── */
    :root {
      --ink:      #0b0d14;
      --paper:    #f4f1ea;
      --navy:     #0f1829;
      --gold:     #c9972b;
      --gold-lt:  #e8b84b;
      --amber:    #f0c060;
      --steel:    #3a4a6b;
      --mist:     #8a9ab8;
      --rule:     rgba(201,151,43,0.35);
      --mono:     'IBM Plex Mono', monospace;
      --serif:    'DM Serif Display', serif;
      --body:     'Fraunces', serif;
      --grid-gap: clamp(1rem, 2vw, 2rem);
    }

    /* ── RESET ───────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--ink);
      color: var(--paper);
      font-family: var(--body);
      font-weight: 300;
      line-height: 1.65;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    /* ── GRID SYSTEM ─────────────────────────────────────── */
    .grid-wrap {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: var(--grid-gap);
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 clamp(1rem, 4vw, 4rem);
    }

    /* ── UTILITY ─────────────────────────────────────────── */
    .mono      { font-family: var(--mono); }
    .gold      { color: var(--gold); }
    .mist      { color: var(--mist); }
    .tag {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--rule);
      padding: .2em .7em;
      display: inline-block;
    }
    .rule-h {
      border: none;
      border-top: 1px solid var(--rule);
    }
    .section-label {
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--mist);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      user-select: none;
    }

    /* ── ANIMATED BACKGROUND GRID ────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--rule) 1px, transparent 1px),
        linear-gradient(90deg, var(--rule) 1px, transparent 1px);
      background-size: 60px 60px;
      opacity: .18;
      pointer-events: none;
      z-index: 0;
    }

    /* ── NAV ─────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      backdrop-filter: blur(12px);
      background: rgba(11,13,20,.85);
      border-bottom: 1px solid var(--rule);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem clamp(1rem, 4vw, 4rem);
      max-width: 1440px;
      margin: 0 auto;
    }
    .nav-logo {
      display: flex;
      flex-direction: column;
      gap: .1rem;
    }
    .nav-logo .wordmark {
      font-family: var(--serif);
      font-size: 1.1rem;
      letter-spacing: .04em;
    }
    .nav-logo .domain {
      font-family: var(--mono);
      font-size: .6rem;
      color: var(--gold);
      letter-spacing: .08em;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }
    .nav-links a {
      font-family: var(--mono);
      font-size: .72rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--mist);
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-cta {
      background: var(--gold);
      color: var(--ink) !important;
      padding: .45em 1.1em;
      font-weight: 600 !important;
    }
    .nav-cta:hover { background: var(--amber) !important; color: var(--ink) !important; }
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: .5rem;
    }
    .hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--paper);
      transition: .3s;
    }

    /* ── HERO ────────────────────────────────────────────── */
    #hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: flex-end;
      padding-top: 80px;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 60% at 70% 40%, rgba(201,151,43,.12) 0%, transparent 70%),
        radial-gradient(ellipse 40% 50% at 10% 80%, rgba(15,24,41,.8) 0%, transparent 80%);
      z-index: 0;
    }
    .hero-content {
      position: relative;
      z-index: 1;
      width: 100%;
      padding-bottom: clamp(3rem, 8vh, 7rem);
    }
    .hero-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: var(--grid-gap);
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 clamp(1rem, 4vw, 4rem);
      align-items: end;
    }
    .hero-text { grid-column: 1 / 9; }
    .hero-meta { grid-column: 10 / 13; display: flex; flex-direction: column; gap: 1.5rem; }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .hero-eyebrow .pulse {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--gold);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50%      { opacity: .5; transform: scale(1.4); }
    }

    h1 {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      line-height: 1.05;
      letter-spacing: -.01em;
      margin-bottom: 1.5rem;
    }
    h1 em {
      font-style: italic;
      color: var(--gold);
    }
    .hero-sub {
      font-size: clamp(.95rem, 1.5vw, 1.1rem);
      color: var(--mist);
      max-width: 56ch;
      margin-bottom: 2.5rem;
    }
    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--ink);
      font-family: var(--mono);
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .9em 2em;
      border: 2px solid var(--gold);
      cursor: pointer;
      transition: background .2s, color .2s;
      display: inline-block;
    }
    .btn-primary:hover { background: transparent; color: var(--gold); }
    .btn-ghost {
      background: transparent;
      color: var(--paper);
      font-family: var(--mono);
      font-size: .8rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .9em 2em;
      border: 1px solid rgba(244,241,234,.25);
      cursor: pointer;
      transition: border-color .2s, color .2s;
      display: inline-block;
    }
    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

    /* Hero meta column */
    .meta-card {
      border: 1px solid var(--rule);
      padding: 1.2rem;
      background: rgba(15,24,41,.6);
    }
    .meta-card .label {
      font-family: var(--mono);
      font-size: .58rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--mist);
      margin-bottom: .5rem;
    }
    .meta-card .value {
      font-family: var(--mono);
      font-size: .85rem;
      color: var(--gold-lt);
    }

    /* ── DIVIDER STRIP ───────────────────────────────────── */
    .clients-strip {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 1.2rem clamp(1rem, 4vw, 4rem);
      background: rgba(15,24,41,.5);
      overflow: hidden;
    }
    .clients-inner {
      display: flex;
      align-items: center;
      gap: 3rem;
      max-width: 1440px;
      margin: 0 auto;
      white-space: nowrap;
    }
    .clients-inner .cl {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--mist);
      opacity: .7;
      flex-shrink: 0;
    }
    .clients-inner .cl strong { color: var(--gold); font-weight: 600; }

    /* ── SECTIONS COMMON ─────────────────────────────────── */
    section { position: relative; z-index: 1; }
    .section-pad { padding: clamp(4rem, 10vh, 9rem) 0; }

    .section-header {
      grid-column: 1 / -1;
      display: flex;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 1rem;
    }
    .section-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      line-height: 1.1;
      flex: 1;
    }
    .section-intro {
      grid-column: 1 / 8;
      color: var(--mist);
      font-size: 1rem;
      margin-bottom: 3rem;
    }

    /* ── SERVICES GRID ───────────────────────────────────── */
    #services { background: var(--navy); }

    .service-card {
      border: 1px solid var(--rule);
      padding: 2rem;
      position: relative;
      background: rgba(11,13,20,.6);
      transition: border-color .3s, transform .3s;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 0;
      background: var(--gold);
      transition: height .4s ease;
    }
    .service-card:hover::before { height: 100%; }
    .service-card:hover { border-color: var(--gold); transform: translateY(-3px); }

    .service-num {
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .2em;
      color: var(--mist);
    }
    .service-icon {
      font-size: 1.8rem;
      line-height: 1;
    }
    .service-title {
      font-family: var(--serif);
      font-size: 1.25rem;
      color: var(--paper);
    }
    .service-desc {
      font-size: .9rem;
      color: var(--mist);
      flex: 1;
    }
    .service-tags {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
    }

    /* card column spans */
    .col-4  { grid-column: span 4; }
    .col-6  { grid-column: span 6; }
    .col-3  { grid-column: span 3; }
    .col-12 { grid-column: 1 / -1; }
    .col-8  { grid-column: span 8; }
    .col-5  { grid-column: span 5; }
    .col-7  { grid-column: span 7; }

    /* ── CREDENTIAL SECTION ──────────────────────────────── */
    #credentials {
      background: var(--ink);
    }
    .cred-showcase {
      grid-column: 1 / 8;
    }
    .cred-sidebar {
      grid-column: 9 / 13;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding-top: 1rem;
    }

    /* W3C VC card mock */
    .vc-card {
      border: 1px solid var(--gold);
      background: linear-gradient(135deg, rgba(15,24,41,.95), rgba(11,13,20,.95));
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }
    .vc-card::after {
      content: '';
      position: absolute;
      top: -30%; right: -20%;
      width: 60%; height: 60%;
      background: radial-gradient(circle, rgba(201,151,43,.12), transparent 70%);
      pointer-events: none;
    }
    .vc-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }
    .vc-badge {
      font-family: var(--mono);
      font-size: .55rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      background: var(--gold);
      color: var(--ink);
      padding: .3em .8em;
      font-weight: 600;
    }
    .vc-logo {
      font-family: var(--serif);
      font-size: 1rem;
      color: var(--gold);
    }
    .vc-field {
      margin-bottom: 1rem;
    }
    .vc-field .fl {
      font-family: var(--mono);
      font-size: .55rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--mist);
      margin-bottom: .2rem;
    }
    .vc-field .fv {
      font-family: var(--mono);
      font-size: .85rem;
      color: var(--paper);
    }
    .vc-hash {
      font-family: var(--mono);
      font-size: .55rem;
      color: rgba(138,154,184,.5);
      word-break: break-all;
      margin-top: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid var(--rule);
    }

    /* cred sidebar items */
    .cred-info {
      border-left: 2px solid var(--rule);
      padding-left: 1.2rem;
    }
    .cred-info h4 {
      font-family: var(--serif);
      font-size: 1.1rem;
      margin-bottom: .4rem;
    }
    .cred-info p {
      font-size: .85rem;
      color: var(--mist);
    }

    /* ── CLIENTS ─────────────────────────────────────────── */
    #clients {
      background: var(--navy);
    }
    .client-grid {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1px;
      border: 1px solid var(--rule);
      margin-top: 2rem;
    }
    .client-cell {
      border: 1px solid var(--rule);
      padding: 2rem 1.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: .7rem;
      transition: background .3s;
    }
    .client-cell:hover { background: rgba(201,151,43,.06); }
    .client-cell .icon { font-size: 2rem; }
    .client-cell .name {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--mist);
    }

    /* ── PROJECTS / REPOS ────────────────────────────────── */
    #projects {
      background: var(--ink);
    }
    .project-card {
      border: 1px solid var(--rule);
      padding: 1.8rem;
      background: rgba(15,24,41,.4);
      transition: border-color .3s;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .project-card:hover { border-color: var(--gold); }
    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
    }
    .project-title {
      font-family: var(--serif);
      font-size: 1.15rem;
    }
    .project-status {
      font-family: var(--mono);
      font-size: .55rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      padding: .25em .7em;
      border: 1px solid;
      white-space: nowrap;
    }
    .status-active { color: #5ecf7a; border-color: rgba(94,207,122,.4); }
    .status-ongoing { color: var(--gold); border-color: var(--rule); }
    .project-desc { font-size: .88rem; color: var(--mist); }
    .project-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1rem;
      border-top: 1px solid var(--rule);
    }
    .repo-link {
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--gold);
      letter-spacing: .08em;
      display: flex;
      align-items: center;
      gap: .4rem;
      transition: opacity .2s;
    }
    .repo-link:hover { opacity: .7; }
    .repo-link svg {
      width: 12px; height: 12px;
      fill: currentColor;
    }
    .project-type {
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .1em;
      color: var(--mist);
      text-transform: uppercase;
    }

    /* ── ABOUT / MANIFESTO ───────────────────────────────── */
    #about {
      background: var(--navy);
      overflow: hidden;
    }
    .manifesto-text {
      grid-column: 2 / 9;
    }
    .manifesto-text p {
      font-size: clamp(1.05rem, 1.8vw, 1.3rem);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .manifesto-stat {
      grid-column: 10 / 13;
      display: flex;
      flex-direction: column;
      gap: 2rem;
      justify-content: center;
    }
    .stat-item {}
    .stat-num {
      font-family: var(--serif);
      font-size: 3rem;
      color: var(--gold);
      line-height: 1;
    }
    .stat-label {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--mist);
      margin-top: .4rem;
    }

    /* large watermark behind manifesto */
    .manifesto-wm {
      position: absolute;
      font-family: var(--serif);
      font-size: clamp(6rem, 14vw, 16rem);
      color: rgba(201,151,43,.04);
      top: 50%; left: 50%;
      transform: translate(-50%,-50%);
      white-space: nowrap;
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }

    /* ── CONTACT ─────────────────────────────────────────── */
    #contact { background: var(--ink); }
    .contact-split {
      grid-column: 1 / 7;
    }
    .contact-split h2 {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      margin-bottom: 1.2rem;
    }
    .contact-split p {
      color: var(--mist);
      margin-bottom: 2rem;
    }
    .contact-detail {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .cd-row {
      display: flex;
      gap: 1rem;
      align-items: baseline;
    }
    .cd-label {
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--mist);
      min-width: 80px;
    }
    .cd-value {
      font-family: var(--mono);
      font-size: .88rem;
      color: var(--gold-lt);
    }
    .contact-form-col {
      grid-column: 8 / 13;
      border: 1px solid var(--rule);
      padding: 2.5rem;
      background: rgba(15,24,41,.5);
    }
    .form-group { margin-bottom: 1.5rem; }
    .form-group label {
      display: block;
      font-family: var(--mono);
      font-size: .6rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--mist);
      margin-bottom: .5rem;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      background: rgba(11,13,20,.8);
      border: 1px solid rgba(138,154,184,.2);
      color: var(--paper);
      font-family: var(--mono);
      font-size: .85rem;
      padding: .8em 1em;
      outline: none;
      transition: border-color .25s;
      appearance: none;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--gold);
    }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    /* ── FOOTER ──────────────────────────────────────────── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--rule);
      padding: 2.5rem clamp(1rem, 4vw, 4rem);
      background: rgba(11,13,20,.9);
    }
    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1.5rem;
      max-width: 1440px;
      margin: 0 auto;
    }
    .footer-left {
      display: flex;
      flex-direction: column;
      gap: .3rem;
    }
    .footer-brand {
      font-family: var(--serif);
      font-size: 1.1rem;
    }
    .footer-domain {
      font-family: var(--mono);
      font-size: .65rem;
      color: var(--gold);
      letter-spacing: .1em;
    }
    .footer-copy {
      font-family: var(--mono);
      font-size: .6rem;
      color: var(--mist);
      letter-spacing: .08em;
    }
    .footer-nav {
      display: flex;
      gap: 1.8rem;
      list-style: none;
      flex-wrap: wrap;
    }
    .footer-nav a {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--mist);
      transition: color .2s;
    }
    .footer-nav a:hover { color: var(--gold); }
    .footer-badges {
      display: flex;
      gap: .7rem;
      flex-wrap: wrap;
    }
    .f-badge {
      font-family: var(--mono);
      font-size: .55rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      border: 1px solid var(--rule);
      padding: .3em .7em;
      color: var(--mist);
    }

    /* ── MOBILE NAV ──────────────────────────────────────── */
    #mobile-menu {
      display: none;
      position: fixed;
      top: 60px; left: 0; right: 0;
      background: rgba(11,13,20,.97);
      border-bottom: 1px solid var(--rule);
      padding: 1.5rem;
      z-index: 99;
      flex-direction: column;
      gap: 1rem;
    }
